<div class="books-grid" id="booksGrid">
  <% if (books.length === 0) { %>
    <div class="empty-state">
      <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
        <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
        <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
      </svg>
      <h3>No books yet</h3>
      <p>Start tracking your reading journey by adding your first book!</p>
      <button class="btn btn-primary" onclick="document.getElementById('addBookBtn').click()">Add Your First Book</button>
    </div>
  <% } else { %>
    <% books.forEach(book => { %>
      <% 
        // Determine the correct Open Library API key type
        let coverType = 'id';
        if (book.cover_id) {
          const cleanId = book.cover_id.trim().toUpperCase();
          if (cleanId.startsWith('OL')) {
            coverType = 'olid';
          } else if (cleanId.length === 10 || cleanId.length === 13) {
            coverType = 'isbn';
          }
        }
      %>
      <div class="book-card" data-id="<%= book.id %>">
        <div class="book-cover">
          <% if (book.cover_id) { %>
            <img 
              src="https://covers.openlibrary.org/b/<%= coverType %>/<%= book.cover_id.trim() %>-M.jpg" 
              alt="<%= book.title %>"
              onerror="this.src='https://via.placeholder.com/200x300?text=No+Cover'"
            >
          <% } else { %>
            <div class="book-cover-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"></path>
                <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"></path>
              </svg>
            </div>
          <% } %>
        </div>
        
        <div class="book-info">
          <h3 class="book-title" title="<%= book.title %>"><%= book.title %></h3>
          <p class="book-author"><%= book.author %></p>
          
          <% if (book.rating) { %>
            <div class="book-rating">
              <% for (let i = 1; i <= 5; i++) { %>
                <span class="star <%= i <= book.rating ? 'filled' : '' %>">★</span>
              <% } %>
            </div>
          <% } %>
          
          <% if (book.date_read) { %>
            <p class="book-date">Read: <%= new Date(book.date_read).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' }) %></p>
          <% } %>
          
          <% if (book.notes) { %>
            <p class="book-notes"><%= book.notes.substring(0, 100) %><%= book.notes.length > 100 ? '...' : '' %></p>
          <% } %>
        </div>
        
        <div class="book-actions">
          <button class="btn-icon btn-edit" data-id="<%= book.id %>" title="Edit">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
            </svg>
          </button>
          <button class="btn-icon btn-delete" data-id="<%= book.id %>" title="Delete">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <polyline points="3 6 5 6 21 6"></polyline>
              <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
            </svg>
          </button>
        </div>
      </div>
    <% }) %>
  <% } %>
</div>